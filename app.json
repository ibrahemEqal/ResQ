{
  "expo": {
    "name": "ResQ",
    "slug": "resq",
    "scheme": "resq",
    "experiments": {
      "typedRoutes": true
    },
    "plugins": [
      "expo-router",
      "expo-sqlite",
      [
        "expo-av",
        {
          "microphonePermission": "اسمح لتطبيق ResQ باستخدام الميكروفون لتسجيل بلاغ صوتي."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "يسمح لتطبيق ResQ بالوصول إلى صورك لإرفاقها مع البلاغ.",
          "cameraPermission": "يسمح لتطبيق ResQ باستخدام الكاميرا لتصوير البلاغ."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#ffffff"
        }
      ]
    ],
    "android": {
      "package": "com.resq.app",
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ]
    },
    "ios": {
      "bundleIdentifier": "com.resq.app",
      "supportsTablet": true,
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "extra": {
      "eas": {
        "projectId": "72253ec7-ccf7-4d1a-a0dd-aa6338cf7a98"
      }
    }
  }
}
