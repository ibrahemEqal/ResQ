{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
  "types": [
    "jest",
    "node"
  ],
    "strict": true,
    "jsx": "react-jsx",
    "paths": {
      "@/*": [
        "./src/*"
      ]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts"
  ]

}